{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { python '.codex/hooks/session_start_policy.py' }\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { python '.codex/hooks/stop_require_validation.py' }\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}

{
  "allowedTools": [
    "Bash(git status)",
    "Bash(git diff*)",
    "Bash(git log*)",
    "Bash(git show*)",
    "Bash(git branch*)",
    "Bash(git stash list*)",
    "Bash(npm run lint*)",
    "Bash(npm run typecheck*)",
    "Bash(npm run test*)",
    "Bash(npm run build*)",
    "Bash(npm run verify*)",
    "Bash(python -m pytest*)",
    "Bash(ruff check*)",
    "Bash(uv run ruff*)",
    "Bash(uv run pytest*)",
    "Bash(ls *)",
    "Bash(find . *)",
    "Bash(cat *)"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { python '.codex/hooks/session_start_policy.py' }\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -Command \"& { python '.codex/hooks/stop_require_validation.py' }\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
